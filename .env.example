VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Used server-side only (Vite dev proxy + Vercel serverless function)
# Do NOT prefix with VITE_ — this keeps the key out of the browser bundle
ANTHROPIC_API_KEY=your_anthropic_api_key

# Overseer daily summary (api/overseer-run.js — Vercel Cron, also testable in dev).
# Needs service-role Supabase access (no user session) + which user to summarise.
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OVERSEER_USER_ID=your_supabase_auth_user_id
# Shared secret protecting /api/overseer-run from public calls (Vercel Cron sends it).
CRON_SECRET=a_long_random_string

# ── AI Inbox: Gmail connector (api/inbox-sync.js) ────────────────────────────
# Polls Gmail for matching messages and imports them into the inbox. Read-only.
# Mint the refresh token once with: node scripts/gmail-auth.mjs  (see that file).
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GMAIL_REFRESH_TOKEN=token_from_scripts/gmail-auth.mjs
# Optional: which Gmail messages to pull. Default: is:starred newer_than:30d
# GMAIL_QUERY=is:starred newer_than:30d
# Which user owns imported rows on the cron path (defaults to OVERSEER_USER_ID).
# INBOX_USER_ID=your_supabase_auth_user_id

# ── Aulë, the coding agent (local only — `npm run agents`) ───────────────────
# The local server runs real Claude Code on your Max plan (NOT the API key).
AULE_TOKEN=a_long_random_string            # gate the localhost WebSocket
AULE_PORT=8787
# Folder Aulë may work in (he's confined here). Default: the parent of this repo,
# so he can edit heyscottybro + your other repos sitting beside it.
# AULE_WORKSPACE=/Users/you/Documents/GitHub
# acceptEdits (auto-accept file edits) | bypassPermissions (full power, incl. shell) | default
AULE_PERMISSION_MODE=acceptEdits
# AULE_MODEL=claude-opus-4-8               # optional model override
# AULE_CLAUDE_PATH=/Users/you/.local/bin/claude   # optional explicit CLI path

# The browser (Command Center) connects to the local Aulë server with these:
VITE_AULE_URL=ws://localhost:8787
VITE_AULE_TOKEN=a_long_random_string       # must match AULE_TOKEN
